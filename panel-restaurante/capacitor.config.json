{
  "appId": "com.pido.restaurante",
  "appName": "Pidoo Partner",
  "webDir": "dist",
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#B91C1C",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "LIGHT",
      "backgroundColor": "#B91C1C"
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "LocalNotifications": {
      "smallIcon": "ic_stat_icon",
      "iconColor": "#B91C1C",
      "sound": "alarm.wav"
    }
  },
  "server": {
    "androidScheme": "https"
  }
}
