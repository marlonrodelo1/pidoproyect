{
  "appId": "co.median.ios.bnlkxpx",
  "appName": "Pidoo",
  "webDir": "dist",
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#FF6B2C",
      "showSpinner": false,
      "androidScaleType": "CENTER_CROP",
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0D0D0D"
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "LocalNotifications": {
      "smallIcon": "ic_stat_icon",
      "iconColor": "#FF6B2C",
      "sound": "alarm.wav"
    },
    "GoogleAuth": {
      "scopes": ["profile", "email"],
      "serverClientId": "797553895667-gr3vsgvcp85k0bh0b3iafkblv529g8kt.apps.googleusercontent.com",
      "forceCodeForRefreshToken": true
    }
  },
  "server": {
    "androidScheme": "https"
  }
}
